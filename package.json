{
  "name": "dripdesk",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @dripdesk/database migrate:dev",
    "db:generate": "pnpm --filter @dripdesk/database generate",
    "db:seed": "pnpm --filter @dripdesk/database seed",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ],
    "overrides": {
      "glob": "^10.5.0",
      "multer": "^2.1.1",
      "picomatch": "^4.0.4",
      "tmp": "^0.2.7",
      "lodash": "^4.18.1",
      "js-yaml": "^4.1.1",
      "ajv": "^8.20.0",
      "file-type": "^22.0.1",
      "qs": "^6.15.2",
      "webpack": "^5.107.2"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
