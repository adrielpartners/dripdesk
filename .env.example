# =============================================================================
# DripDesk Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
# =============================================================================

# ---- Environment -----------------------------------------------------------
# Options: development | test | production
DRIPDESK_ENV=development
DRIPDESK_API_PORT=3000
DRIPDESK_PUBLIC_API_URL=http://localhost:3000
DRIPDESK_PUBLIC_WEB_URL=http://localhost:3001
DRIPDESK_LOG_LEVEL=debug
DRIPDESK_ENABLE_API_DOCS=true

# ---- Database --------------------------------------------------------------
# Local Postgres with Docker: docker compose -f docker/docker-compose.yml up postgres -d
# The default user/password match docker/docker-compose.yml
DRIPDESK_DATABASE_URL="postgresql://dripdesk:dripdesk@localhost:5432/dripdesk?schema=public"

# ---- Redis -----------------------------------------------------------------
# Local Redis with Docker: docker compose -f docker/docker-compose.yml up redis -d
DRIPDESK_REDIS_URL="redis://localhost:6379"

# ---- Critical Security Secrets (MUST be set in production) -----------------
# Generate with:
#   openssl rand -base64 32   # DRIPDESK_SESSION_SECRET & DRIPDESK_PASSWORD_PEPPER
#   openssl rand -hex 32      # DRIPDESK_ENCRYPTION_KEY
#
# WARNING: Running without these gives a startup warning in dev
#          and will crash in production.
DRIPDESK_SESSION_SECRET=
DRIPDESK_ENCRYPTION_KEY=
DRIPDESK_PASSWORD_PEPPER=

# ---- JWT -------------------------------------------------------------------
DRIPDESK_JWT_EXPIRES_IN=7d

# ---- Stripe (required for billing features) --------------------------------
DRIPDESK_STRIPE_SECRET_KEY=
DRIPDESK_STRIPE_WEBHOOK_SECRET=
DRIPDESK_STRIPE_CORE_PRICE_ID=
DRIPDESK_STRIPE_PLUS_PRICE_ID=
DRIPDESK_STRIPE_PRO_PRICE_ID=

# ---- Email / SMTP ----------------------------------------------------------
# Fallback SMTP for transactional emails (password reset, invites, etc.).
# Org-owned provider credentials are stored encrypted in the database.
DRIPDESK_DEFAULT_FROM_EMAIL=noreply@dripdesk.net
DRIPDESK_DEFAULT_FROM_NAME=DripDesk
DRIPDESK_SMTP_HOST=localhost
DRIPDESK_SMTP_PORT=1025
DRIPDESK_SMTP_USER=
DRIPDESK_SMTP_PASSWORD=

# ---- Worker -----------------------------------------------------------------
DRIPDESK_WORKER_CONCURRENCY=5