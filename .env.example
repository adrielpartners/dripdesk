# =============================================================================
# DripDesk Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
# =============================================================================

# ---- Environment -----------------------------------------------------------
DRIPDESK_ENV=development
DRIPDESK_API_PORT=3000
DRIPDESK_PUBLIC_API_URL=http://localhost:3000
DRIPDESK_PUBLIC_WEB_URL=http://localhost:3001
DRIPDESK_LOG_LEVEL=debug
DRIPDESK_ENABLE_API_DOCS=true

# ---- Database --------------------------------------------------------------
# Dev password matches docker/docker-compose.yml (POSTGRES_PASSWORD=dripdesk).
# Prod: replace *** with ${DRIPDESK_POSTGRES_PASSWORD} or a real secret.
DRIPDESK_DATABASE_URL=postgresql://dripdesk:***@localhost:5432/dripdesk?schema=public

# ---- Redis -----------------------------------------------------------------
# Dev: docker compose -f docker/docker-compose.yml up redis -d (port 6379, no auth)
# Prod: point to your Redis endpoint
DRIPDESK_REDIS_URL=redis://localhost:6379

# ---- Critical Security Secrets (MUST be set in production) -----------------
# Generate with:
#   openssl rand -base64 32   # DRIPDESK_SESSION_SECRET & DRIPDESK_PASSWORD_PEPPER
#   openssl rand -hex 32      # DRIPDESK_ENCRYPTION_KEY
DRIPDESK_SESSION_SECRET=change-me-session-secret-base64
DRIPDESK_ENCRYPTION_KEY=change-me-encryption-key-hex
DRIPDESK_PASSWORD_PEPPER=change-me-password-pepper-base64

# ---- JWT -------------------------------------------------------------------
DRIPDESK_JWT_EXPIRES_IN=7d

# ---- Stripe (required for billing features) --------------------------------
# Set these to your Stripe price IDs. Leave empty to disable billing.
DRIPDESK_STRIPE_SECRET_KEY=
DRIPDESK_STRIPE_WEBHOOK_SECRET=
DRIPDESK_STRIPE_FREE_PRICE_ID=
DRIPDESK_STRIPE_CORE_PRICE_ID=
DRIPDESK_STRIPE_PLUS_PRICE_ID=
DRIPDESK_STRIPE_PRO_PRICE_ID=

# ---- SMTP / Email (dev default uses Mailpit at localhost:1025) -------------
DRIPDESK_DEFAULT_FROM_NAME=DripDesk
DRIPDESK_SMTP_HOST=localhost
DRIPDESK_SMTP_PORT=1025
DRIPDESK_SMTP_USER=
DRIPDESK_SMTP_PASSWORD=

# ---- Worker -----------------------------------------------------------------
DRIPDESK_WORKER_CONCURRENCY=5