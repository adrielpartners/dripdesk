# App
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
APP_URL=http://localhost:3001

# Database
DATABASE_URL="postgresql://dripdesk:dripdesk@localhost:5432/dripdesk?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your-jwt-secret-change-me-in-production
JWT_EXPIRES_IN=7d

# Encryption (for storing provider credentials)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# System Email (for magic links and notifications)
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=noreply@dripdesk.com
DEFAULT_FROM_NAME=DripDesk

# Frontend
NUXT_PUBLIC_API_URL=http://localhost:3000
NUXT_PUBLIC_APP_URL=http://localhost:3001
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
