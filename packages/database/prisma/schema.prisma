generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DRIPDESK_DATABASE_URL")
}

model Organization {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String   @unique
  defaultTimezone String   @default("UTC") @map("default_timezone")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  members OrganizationMember[]
  persons Person[]
  personChannels PersonChannel[]
  campaigns Campaign[]
  enrollments Enrollment[]
  messageOutbox MessageOutbox[]
  messageEvents MessageEvent[]
  trackedLinks TrackedLink[]
  providerCredentials ProviderCredential[]
  unsubscribeTokens UnsubscribeToken[]
  unsubscribeEvents UnsubscribeEvent[]
  billingSubscription BillingSubscription?
  inviteTokens        InviteToken[]

  @@index([slug], map: "organizations_slug_idx")
  @@map("organizations")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  passwordHash String?   @map("password_hash")
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  role         UserRole  @default(recipient)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)

  memberships         OrganizationMember[]
  passwordResetTokens PasswordResetToken[]
  personRecords       Person[]
  createdCampaigns    Campaign[]
  createdInvites      InviteToken[]

  @@index([email], map: "users_email_idx")
  @@map("users")
}

model Person {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String       @map("organization_id") @db.Uuid
  userId              String?      @map("user_id") @db.Uuid
  displayName         String       @map("display_name")
  timezone            String?      @map("timezone")
  status              PersonStatus @default(active)
  tags                String[]     @default([])
  deletionRequestedAt DateTime?    @map("deletion_requested_at") @db.Timestamptz(6)
  archivedAt          DateTime?    @map("archived_at") @db.Timestamptz(6)
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  channels     PersonChannel[]
  enrollments Enrollment[]
  messageOutbox MessageOutbox[]
  trackedLinks TrackedLink[]
  unsubscribeTokens UnsubscribeToken[]
  unsubscribeEvents UnsubscribeEvent[]

  @@index([organizationId, status], map: "persons_organization_id_status_idx")
  @@index([organizationId, displayName], map: "persons_organization_id_display_name_idx")
  @@index([userId], map: "persons_user_id_idx")
  @@map("persons")
}

model PersonChannel {
  id                 String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String                          @map("organization_id") @db.Uuid
  personId           String                          @map("person_id") @db.Uuid
  channelType        PersonChannelType               @map("channel_type")
  address            String
  verificationStatus PersonChannelVerificationStatus @default(unverified) @map("verification_status")
  enabled            Boolean                         @default(true)
  unsubscribed       Boolean                         @default(false)
  suppressed         Boolean                         @default(false)
  providerMetadata   Json?                           @map("provider_metadata")
  createdAt          DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  messageOutbox MessageOutbox[]

  @@unique([organizationId, channelType, address], map: "person_channels_organization_id_channel_type_address_key")
  @@index([organizationId, channelType], map: "person_channels_organization_id_channel_type_idx")
  @@index([personId], map: "person_channels_person_id_idx")
  @@map("person_channels")
}

model Campaign {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  createdById    String               @map("created_by_id") @db.Uuid
  name           String
  description    String?
  status         CampaignStatus       @default(draft)
  scheduleType   CampaignScheduleType @default(daily) @map("schedule_type")
  scheduleConfig Json?                @map("schedule_config")
  progressRule   CampaignProgressRule @default(time_based) @map("progress_rule")
  mode           CampaignMode         @default(standard)
  defaultChannels PersonChannelType[] @default([email]) @map("default_channels")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  activatedAt    DateTime?            @map("activated_at") @db.Timestamptz(6)
  archivedAt     DateTime?            @map("archived_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  steps        CampaignStep[]
  enrollments  Enrollment[]
  messageOutbox MessageOutbox[]
  trackedLinks TrackedLink[]
  unsubscribeTokens UnsubscribeToken[]
  unsubscribeEvents UnsubscribeEvent[]

  @@index([organizationId, status], map: "campaigns_organization_id_status_idx")
  @@index([organizationId, createdAt], map: "campaigns_organization_id_created_at_idx")
  @@map("campaigns")
}

model CampaignStep {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId           String             @map("campaign_id") @db.Uuid
  stepOrder            Int                @map("step_order")
  title                String
  status               CampaignStepStatus @default(draft)
  defaultContent       String?            @map("default_content")
  smsContent           String?            @map("sms_content")
  telegramContent      String?            @map("telegram_content")
  emailSubject         String?            @map("email_subject")
  emailBody            String?            @map("email_body")
  delayDaysOverride    Int?               @map("delay_days_override")
  channelOverrides     PersonChannelType[] @default([]) @map("channel_overrides")
  replyRequiredPhrases String[]           @default([]) @map("reply_required_phrases")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt           DateTime?          @map("archived_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  enrollmentStepStates EnrollmentStepState[]
  messageOutbox MessageOutbox[]
  trackedLinks TrackedLink[]

  @@unique([campaignId, stepOrder], map: "campaign_steps_campaign_id_step_order_key")
  @@index([campaignId, status], map: "campaign_steps_campaign_id_status_idx")
  @@map("campaign_steps")
}

model Enrollment {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  campaignId       String           @map("campaign_id") @db.Uuid
  personId         String           @map("person_id") @db.Uuid
  status           EnrollmentStatus @default(active)
  currentStepOrder Int              @default(1) @map("current_step_order")
  enrolledAt       DateTime         @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  pausedAt         DateTime?        @map("paused_at") @db.Timestamptz(6)
  removedAt        DateTime?        @map("removed_at") @db.Timestamptz(6)
  completedAt      DateTime?        @map("completed_at") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  stepStates   EnrollmentStepState[]
  messageOutbox MessageOutbox[]
  messageEvents MessageEvent[]
  trackedLinks TrackedLink[]
  unsubscribeTokens UnsubscribeToken[]
  unsubscribeEvents UnsubscribeEvent[]

  @@unique([personId, campaignId], map: "enrollments_person_id_campaign_id_key")
  @@index([organizationId, status], map: "enrollments_organization_id_status_idx")
  @@index([campaignId, status], map: "enrollments_campaign_id_status_idx")
  @@index([personId, status], map: "enrollments_person_id_status_idx")
  @@index([organizationId, enrolledAt], map: "enrollments_organization_id_enrolled_at_idx")
  @@map("enrollments")
}

model EnrollmentStepState {
  id             String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId   String                    @map("enrollment_id") @db.Uuid
  campaignStepId String                    @map("campaign_step_id") @db.Uuid
  stepOrder      Int                       @map("step_order")
  status         EnrollmentStepStateStatus @default(pending)
  sentAt         DateTime?                 @map("sent_at") @db.Timestamptz(6)
  deliveredAt    DateTime?                 @map("delivered_at") @db.Timestamptz(6)
  clickedAt      DateTime?                 @map("clicked_at") @db.Timestamptz(6)
  repliedAt      DateTime?                 @map("replied_at") @db.Timestamptz(6)
  completedAt    DateTime?                 @map("completed_at") @db.Timestamptz(6)
  failedAt       DateTime?                 @map("failed_at") @db.Timestamptz(6)
  skippedAt      DateTime?                 @map("skipped_at") @db.Timestamptz(6)
  unsubscribedAt DateTime?                 @map("unsubscribed_at") @db.Timestamptz(6)
  createdAt      DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)

  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  campaignStep CampaignStep @relation(fields: [campaignStepId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, campaignStepId], map: "enrollment_step_states_enrollment_id_campaign_step_id_key")
  @@index([enrollmentId, status], map: "enrollment_step_states_enrollment_id_status_idx")
  @@index([campaignStepId], map: "enrollment_step_states_campaign_step_id_idx")
  @@map("enrollment_step_states")
}

model MessageOutbox {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String             @map("organization_id") @db.Uuid
  enrollmentId    String             @map("enrollment_id") @db.Uuid
  campaignId      String             @map("campaign_id") @db.Uuid
  campaignStepId  String             @map("campaign_step_id") @db.Uuid
  personId        String             @map("person_id") @db.Uuid
  personChannelId String             @map("person_channel_id") @db.Uuid
  channelType     PersonChannelType  @map("channel_type")
  status          MessageOutboxStatus @default(prepared)
  subject         String?
  body            String
  provider        String?
  providerMessageId String?          @map("provider_message_id")
  preparedAt      DateTime           @default(now()) @map("prepared_at") @db.Timestamptz(6)
  sentAt          DateTime?          @map("sent_at") @db.Timestamptz(6)
  failedAt        DateTime?          @map("failed_at") @db.Timestamptz(6)
  errorMessage    String?            @map("error_message")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollment    Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  campaign      Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignStep  CampaignStep  @relation(fields: [campaignStepId], references: [id], onDelete: Cascade)
  person        Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
  personChannel PersonChannel @relation(fields: [personChannelId], references: [id], onDelete: Restrict)
  events        MessageEvent[]
  trackedLinks  TrackedLink[]
  unsubscribeTokens UnsubscribeToken[]

  @@unique([enrollmentId, campaignStepId, channelType], map: "message_outbox_enrollment_id_campaign_step_id_channel_type_key")
  @@index([organizationId, status], map: "message_outbox_organization_id_status_idx")
  @@index([enrollmentId], map: "message_outbox_enrollment_id_idx")
  @@index([campaignStepId], map: "message_outbox_campaign_step_id_idx")
  @@map("message_outbox")
}

model MessageEvent {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  enrollmentId   String?          @map("enrollment_id") @db.Uuid
  messageOutboxId String?         @map("message_outbox_id") @db.Uuid
  trackedLinkId  String?          @map("tracked_link_id") @db.Uuid
  eventType      MessageEventType @map("event_type")
  metadata       Json?
  occurredAt     DateTime         @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollment   Enrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  messageOutbox MessageOutbox? @relation(fields: [messageOutboxId], references: [id], onDelete: SetNull)
  trackedLink  TrackedLink? @relation(fields: [trackedLinkId], references: [id], onDelete: SetNull)

  @@index([organizationId, eventType], map: "message_events_organization_id_event_type_idx")
  @@index([enrollmentId], map: "message_events_enrollment_id_idx")
  @@index([messageOutboxId], map: "message_events_message_outbox_id_idx")
  @@index([trackedLinkId], map: "message_events_tracked_link_id_idx")
  @@map("message_events")
}

model TrackedLink {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  enrollmentId    String    @map("enrollment_id") @db.Uuid
  campaignId      String    @map("campaign_id") @db.Uuid
  campaignStepId  String    @map("campaign_step_id") @db.Uuid
  personId        String    @map("person_id") @db.Uuid
  messageOutboxId String?   @map("message_outbox_id") @db.Uuid
  token           String    @unique
  originalUrl     String    @map("original_url")
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz(6)
  clickedAt       DateTime? @map("clicked_at") @db.Timestamptz(6)
  clickCount      Int       @default(0) @map("click_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignStep CampaignStep @relation(fields: [campaignStepId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  messageOutbox MessageOutbox? @relation(fields: [messageOutboxId], references: [id], onDelete: SetNull)
  events       MessageEvent[]

  @@index([organizationId], map: "tracked_links_organization_id_idx")
  @@index([enrollmentId], map: "tracked_links_enrollment_id_idx")
  @@index([campaignStepId], map: "tracked_links_campaign_step_id_idx")
  @@map("tracked_links")
}

model ProviderCredential {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String                   @map("organization_id") @db.Uuid
  providerType    ProviderCredentialType   @map("provider_type")
  encryptedConfig String                   @map("encrypted_config")
  maskedConfig    Json                     @map("masked_config")
  twilioAccountSid String?                @map("twilio_account_sid")
  status          ProviderCredentialStatus @default(configured)
  lastTestedAt    DateTime?                @map("last_tested_at") @db.Timestamptz(6)
  lastError       String?                  @map("last_error")
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, providerType], map: "provider_credentials_organization_id_provider_type_key")
  @@index([twilioAccountSid], map: "provider_credentials_twilio_account_sid_idx")
  @@index([organizationId], map: "provider_credentials_organization_id_idx")
  @@map("provider_credentials")
}

model UnsubscribeToken {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  personId        String    @map("person_id") @db.Uuid
  campaignId      String?   @map("campaign_id") @db.Uuid
  enrollmentId    String?   @map("enrollment_id") @db.Uuid
  messageOutboxId String?   @map("message_outbox_id") @db.Uuid
  tokenHash       String    @unique @map("token_hash")
  usedAt          DateTime? @map("used_at") @db.Timestamptz(6)
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  enrollment   Enrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  messageOutbox MessageOutbox? @relation(fields: [messageOutboxId], references: [id], onDelete: SetNull)

  @@index([organizationId], map: "unsubscribe_tokens_organization_id_idx")
  @@index([personId], map: "unsubscribe_tokens_person_id_idx")
  @@index([campaignId], map: "unsubscribe_tokens_campaign_id_idx")
  @@map("unsubscribe_tokens")
}

model UnsubscribeEvent {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  personId       String           @map("person_id") @db.Uuid
  campaignId     String?          @map("campaign_id") @db.Uuid
  enrollmentId   String?          @map("enrollment_id") @db.Uuid
  eventType      UnsubscribeEventType @map("event_type")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  enrollment   Enrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([organizationId, eventType], map: "unsubscribe_events_organization_id_event_type_idx")
  @@index([personId], map: "unsubscribe_events_person_id_idx")
  @@map("unsubscribe_events")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "password_reset_tokens_user_id_idx")
  @@index([expiresAt], map: "password_reset_tokens_expires_at_idx")
  @@map("password_reset_tokens")
}

model BillingSubscription {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String        @unique @map("organization_id") @db.Uuid
  planId               String        @default("free") @map("plan_id")
  status               BillingStatus @default(inactive)
  activeContactLimit   Int?          @map("active_contact_limit")
  stripeCustomerId     String?       @map("stripe_customer_id")
  stripeSubscriptionId String?       @unique @map("stripe_subscription_id")
  currentPeriodEnd     DateTime?     @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean       @default(false) @map("cancel_at_period_end")
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status], map: "billing_subscriptions_organization_id_status_idx")
  @@index([stripeCustomerId], map: "billing_subscriptions_stripe_customer_id_idx")
  @@map("billing_subscriptions")
}

model OrganizationMember {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  userId         String                 @map("user_id") @db.Uuid
  role           OrganizationMemberRole
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId], map: "organization_members_organization_id_user_id_key")
  @@index([organizationId], map: "organization_members_organization_id_idx")
  @@index([userId], map: "organization_members_user_id_idx")
  @@map("organization_members")
}

model InviteToken {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  invitedBy      String   @map("invited_by") @db.Uuid
  email          String
  role           String   @default("admin")
  tokenHash      String   @unique @map("token_hash")
  usedAt         DateTime? @map("used_at") @db.Timestamptz(6)
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedByUser User        @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "invite_tokens_organization_id_idx")
  @@index([email], map: "invite_tokens_email_idx")
  @@map("invite_tokens")
}

enum UserRole {
  owner
  admin
  recipient

  @@map("user_role")
}

enum OrganizationMemberRole {
  owner
  admin

  @@map("organization_member_role")
}

enum PersonStatus {
  active
  archived
  deletion_requested

  @@map("person_status")
}

enum PersonChannelType {
  sms
  telegram
  email

  @@map("person_channel_type")
}

enum PersonChannelVerificationStatus {
  unverified
  verified

  @@map("person_channel_verification_status")
}

enum CampaignStatus {
  draft
  active
  paused
  completed
  archived

  @@map("campaign_status")
}

enum CampaignScheduleType {
  daily
  weekdays
  monday_wednesday_friday
  custom_interval
  custom_days_of_week

  @@map("campaign_schedule_type")
}

enum CampaignProgressRule {
  time_based
  link_click_required
  reply_required

  @@map("campaign_progress_rule")
}

enum CampaignMode {
  standard
  advanced

  @@map("campaign_mode")
}

enum CampaignStepStatus {
  draft
  published
  archived

  @@map("campaign_step_status")
}

enum EnrollmentStatus {
  active
  paused
  completed
  removed

  @@map("enrollment_status")
}

enum EnrollmentStepStateStatus {
  pending
  queued
  sent
  delivered
  clicked
  replied
  completed
  failed
  skipped
  unsubscribed

  @@map("enrollment_step_state_status")
}

enum MessageOutboxStatus {
  prepared
  sending
  sent
  failed

  @@map("message_outbox_status")
}

enum MessageEventType {
  queued
  prepared
  sent
  delivered
  failed
  opened
  clicked
  replied
  completed
  unsubscribed

  @@map("message_event_type")
}

enum ProviderCredentialType {
  twilio
  telegram
  smtp

  @@map("provider_credential_type")
}

enum ProviderCredentialStatus {
  configured
  verified
  failed

  @@map("provider_credential_status")
}

enum UnsubscribeEventType {
  campaign_unsubscribed
  global_unsubscribed
  deletion_requested

  @@map("unsubscribe_event_type")
}

enum BillingStatus {
  trial
  active
  past_due
  canceled
  inactive

  @@map("billing_status")
}
